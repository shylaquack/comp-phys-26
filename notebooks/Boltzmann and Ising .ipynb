    "\n",
    "def energy(state, J=1., H=0.):\n",
    "    E = -J * (\n",
    "        np.sum(state * np.roll(state, 1, axis=0)) + \\\n",
    "        np.sum(state * np.roll(state, 1, axis=1))\n",
    "    )\n",
    "    E += -H * np.sum(state)\n",
    "    return E"
   ]
